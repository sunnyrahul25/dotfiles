! remove Caps Lock
clear Lock
! add Mode_switch, Escape is caps lock
keycode 66 = Mode_switch  Mode_switch
keycode 45 = k K Up
keycode 43 = h H Left
keycode 44 = j J Down
keycode 46 = l L Right
keysym i = i I Home
keysym o = o O End
! mpping missed key on my laptop
keycode 39 = s S a
! semicolon
keycode 47 = semicolon colon F6 
