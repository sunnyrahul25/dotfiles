alias vim='nvim'
alias mux='pgrep -vx tmux > /dev/null && tmux new -d -s delete-me && tmux run-shell ~/.tmux/plugins/tmux-resurrect/scripts/restore.sh && tmux kill-session -t delete-me && tmux attach || tmux attach'

# arandr monitor settings
alias shm='~/.screenlayout/home-single-monitor.sh'
alias shv='~/.screenlayout/vertical-monitor.sh'
# utilities
alias cp="cp -i"                          # confirm before overwriting something
alias df='df -h'                          # human-readable sizes
alias free='free -m'                      # show sizes in MB
alias more=less
alias gh="cd ~/"

# Git specific
alias g='git'

# dotbare specific
alias dot='dotbare'
alias dff='dotbare fadd -f'
alias dfd='dotbare fadd -d'
alias dfe='dotbare fedit'
alias dfs='dotbare fstat'
alias dfl='dotbare flog'
# tmux scratchpad
alias tsp='tmux attach -t scratchpad'
# youtube dl
alias ydl='youtube-dl -f best'
# pomodoros
alias b10='bash ~/pomo.sh 600'
alias b20='bash ~/pomo.sh 1200'
alias p1='bash ~/pomo.sh 3000'
alias p2='bash ~/pomo.sh 6000'
alias p3='bash ~/pomo.sh 12000'
alias p4='bash ~/pomo.sh 18000'
